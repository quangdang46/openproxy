---
import Layout from '@/layouts/Layout.astro';
import MediaProvidersKindPageClient from '@/components/MediaProvidersKindPageClient';
import { MEDIA_PROVIDER_KINDS } from '@/shared/constants/providers';
import DashboardLayout from '@/shared/components/layouts/DashboardLayout';

export async function getStaticPaths() {
  return MEDIA_PROVIDER_KINDS.map((k) => ({ params: { kind: k.id } }));
}
---
<Layout>
  <DashboardLayout client:only="react">
    <MediaProvidersKindPageClient client:only="react" />
  </DashboardLayout>
</Layout>
