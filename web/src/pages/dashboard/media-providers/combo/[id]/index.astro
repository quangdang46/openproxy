---
import Layout from '@/layouts/Layout.astro';
import MediaProvidersComboIdPageClient from '@/components/MediaProvidersComboIdPageClient';
import DashboardLayout from '@/shared/components/layouts/DashboardLayout';

export async function getStaticPaths() {
  // Single dynamic shell — combo ids are runtime UUIDs unknown at build time.
  return [{ params: { id: '_dynamic' } }];
}
---
<Layout>
  <DashboardLayout client:only="react">
    <MediaProvidersComboIdPageClient client:only="react" />
  </DashboardLayout>
</Layout>
