---
// `/login` — Dashboard login page.
// Handles first-login password entry and session creation.
import Layout from '@/layouts/Layout.astro';

const INITIAL_PASSWORD = '123456';
---
<Layout title="OpenProxy - Login">
  <div class="min-h-screen flex items-center justify-center bg-canvas px-4 py-12 relative overflow-hidden">
    <!-- Decorative editorial backdrop: a subtle cream wash with a faint grid -->
    <div class="landing-grid absolute inset-0 pointer-events-none -z-10" aria-hidden="true"></div>

    <div class="w-full max-w-md relative">
      <!-- Editorial wordmark -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-mini-md bg-surface-card border border-hairline mb-5">
          <!-- Anthropic-style spike mark in coral -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="text-brand-coral" aria-hidden="true">
            <path d="M11.0 2.2 L13.0 2.2 L13.4 10.0 L20.0 8.4 L20.5 10.3 L13.6 11.45 L20.5 13.7 L20.0 15.6 L13.4 14.0 L13.0 21.8 L11.0 21.8 L10.6 14.0 L4.0 15.6 L3.5 13.7 L10.4 11.45 L3.5 10.3 L4.0 8.4 L10.6 10.0 Z" />
          </svg>
        </div>
        <h1 class="font-serif font-normal text-[40px] leading-tight tracking-[-0.02em] text-ink mb-2">
          OpenProxy
        </h1>
        <p class="text-[15px] text-body">Sign in to your dashboard</p>
      </div>

      <!-- Login Form -->
      <div class="bg-surface-card rounded-mini-xl border border-hairline-soft p-8">
        <form id="login-form" class="space-y-5">
          <div>
            <label for="password" class="block text-[13px] font-medium text-body-strong mb-2">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autocomplete="current-password"
              class="w-full h-10 px-3 rounded-mini-md border border-hairline bg-canvas text-ink text-[14px] placeholder:text-muted-soft focus:outline-none focus:ring-2 focus:ring-brand-coral/30 focus:border-brand-coral/60 transition"
              placeholder="Enter your password"
            />
          </div>

          <div id="error-msg" class="hidden text-sm text-[color:var(--color-danger)] bg-[color:var(--color-danger)]/10 border border-[color:var(--color-danger)]/20 rounded-mini-md px-3 py-2">
          </div>

          <button
            type="submit"
            id="login-btn"
            class="w-full inline-flex items-center justify-center gap-2 h-11 px-4 rounded-mini-md bg-brand-coral text-on-primary text-[14px] font-medium hover:bg-brand-coral-active transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-coral/30 focus-visible:ring-offset-2 focus-visible:ring-offset-canvas disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="btn-text">Sign In</span>
            <span id="btn-spinner" class="hidden">
              <svg class="animate-spin h-4 w-4 text-on-primary" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </span>
          </button>
        </form>

        <!-- First-login hint -->
        <div id="first-login-hint" class="mt-5 pt-5 border-t border-hairline-soft text-[12px] text-muted text-center">
          Default password: <code class="px-1.5 py-0.5 rounded bg-canvas border border-hairline-soft font-mono text-ink">{INITIAL_PASSWORD}</code>
        </div>
      </div>

      <p class="mt-8 text-center text-[12px] text-muted-soft">
        OpenProxy &middot; local AI router for Claude Code, Codex, Cursor &amp; more
      </p>
    </div>
  </div>

  <script>
    const form = document.getElementById('login-form') as HTMLFormElement;
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text') as HTMLSpanElement;
    const btnSpinner = document.getElementById('btn-spinner') as HTMLSpanElement;
    const firstLoginHint = document.getElementById('first-login-hint') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      loginBtn.disabled = true;
      btnText.textContent = 'Signing in...';
      btnSpinner.classList.remove('hidden');

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: passwordInput.value }),
        });

        const data = await res.json();

        if (res.ok && (data.success || data.authenticated)) {
          // Check if this is first login (default password)
          if (passwordInput.value === '{INITIAL_PASSWORD}') {
            firstLoginHint.classList.remove('hidden');
            firstLoginHint.innerHTML = '<span class="text-warning">This is the default password. Change it in Settings → Security after logging in.</span>';
          }
          window.location.href = '/dashboard';
        } else {
          errorMsg.textContent = data.error || 'Invalid password. Please try again.';
          errorMsg.classList.remove('hidden');
          passwordInput.value = '';
          passwordInput.focus();
        }
      } catch (err) {
        errorMsg.textContent = 'Connection failed. Is the server running?';
        errorMsg.classList.remove('hidden');
      } finally {
        loginBtn.disabled = false;
        btnText.textContent = 'Sign In';
        btnSpinner.classList.add('hidden');
      }
    });

    // Focus password field on load
    passwordInput.focus();
  </script>
</Layout>
