---
// OAuth callback relay page.
// The OAuth provider redirects the popup here after authentication.
// This page reads the auth code from URL params and communicates it back to
// the parent window (the OpenProxy dashboard) via BroadcastChannel,
// localStorage events, and postMessage.
// This component is rendered server-side; the interactive logic runs on the
// client in the <script> block below.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OpenProxy — OAuth Callback</title>
    <style is:global>
      *,
      *::before,
      *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        background: #0d0d0d;
        color: #e5e5e5;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        line-height: 1.6;
      }
      .card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 2rem;
        max-width: 480px;
        width: 90%;
        text-align: center;
      }
      .spinner {
        display: inline-block;
        width: 24px;
        height: 24px;
        border: 3px solid #2a2a2a;
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin-bottom: 1rem;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      h1 { font-size: 1.25rem; margin-bottom: 0.75rem; }
      p  { font-size: 0.875rem; color: #9ca3af; }
      .error { color: #ef4444; }
      .success { color: #22c55e; }
    </style>
  </head>
  <body>
    <div class="card" id="card">
      <div class="spinner" id="spinner"></div>
      <h1 id="title">Processing authentication…</h1>
      <p id="message">Communicating with the OpenProxy dashboard.</p>
    </div>

    <script>
      (function () {
        var card = document.getElementById('card');
        var spinner = document.getElementById('spinner');
        var title = document.getElementById('title');
        var msg = document.getElementById('message');

        var params = new URLSearchParams(window.location.search);
        var code = params.get('code');
        var state = params.get('state');
        var error = params.get('error');
        var errorDescription = params.get('error_description');

        var data = {
          code: code,
          state: state,
          error: error,
          errorDescription: errorDescription,
          timestamp: Date.now(),
        };

        var sentByChannel = false;
        var sentByStorage = false;
        var sentByMessage = false;

        function markSent() {
          if (sentByChannel || sentByStorage || sentByMessage) return;
          spinner.style.display = 'block';
        }

        // Method 1: BroadcastChannel
        try {
          var channel = new BroadcastChannel('oauth_callback');
          channel.postMessage(data);
          channel.close();
          sentByChannel = true;
        } catch (e) {
          // BroadcastChannel not supported — fall through
        }

        // Method 2: localStorage event (triggers 'storage' event in other tabs)
        try {
          localStorage.setItem('oauth_callback', JSON.stringify(data));
          setTimeout(function () {
            try { localStorage.removeItem('oauth_callback'); } catch (_) {}
          }, 1000);
          sentByStorage = true;
        } catch (e) {
          // localStorage unavailable — fall through
        }

        // Method 3: postMessage to opener
        try {
          if (window.opener && !window.opener.closed) {
            window.opener.postMessage(
              { type: 'oauth_callback', data: data },
              window.location.origin
            );
            sentByMessage = true;
          }
        } catch (e) {
          // Cross-origin opener — fall through
        }

        // Update UI based on result
        if (error) {
          spinner.style.display = 'none';
          title.textContent = 'Authentication Failed';
          title.className = 'error';
          msg.textContent = errorDescription || error;
        } else if (code) {
          spinner.style.display = 'none';
          title.textContent = 'Authentication Complete';
          title.className = 'success';
          msg.textContent = 'You can close this window and return to the dashboard.';

          // Auto-close after 2 seconds
          setTimeout(function () {
            if (window.opener && !window.opener.closed) {
              window.close();
            }
          }, 2000);
        } else {
          // No code or error — show URL instructions
          spinner.style.display = 'none';
          title.textContent = 'No Auth Data Found';
          msg.innerHTML =
            'The URL did not contain OAuth parameters. ' +
            'Please copy the full URL from your browser\'s address bar and ' +
            'paste it into the <strong>Callback URL</strong> field in the OpenProxy dashboard.';
        }

        // Fallback: if none of the communication methods worked, show copy-paste instructions
        if (!sentByChannel && !sentByStorage && !sentByMessage) {
          // Show the URL as a fallback for manual copy-paste
          var urlMsg = document.createElement('p');
          urlMsg.style.cssText = 'margin-top: 1rem; font-size: 0.75rem; color: #6b7280; word-break: break-all;';
          urlMsg.textContent = 'Full URL: ' + window.location.href;
          card.appendChild(urlMsg);

          // Add a copy button
          var copyBtn = document.createElement('button');
          copyBtn.textContent = 'Copy URL';
          copyBtn.style.cssText =
            'margin-top: 0.75rem; padding: 0.5rem 1rem; background: #6366f1; color: white; ' +
            'border: none; border-radius: 6px; cursor: pointer; font-size: 0.8rem;';
          copyBtn.onclick = function () {
            navigator.clipboard.writeText(window.location.href).catch(function () {
              // Fallback for older browsers
              var ta = document.createElement('textarea');
              ta.value = window.location.href;
              ta.style.position = 'fixed';
              ta.style.opacity = '0';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
            });
            copyBtn.textContent = 'Copied!';
            setTimeout(function () { copyBtn.textContent = 'Copy URL'; }, 2000);
          };
          card.appendChild(copyBtn);
        }
      })();
    </script>
  </body>
</html>
