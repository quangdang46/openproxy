# =============================================================================
# OpenProxy Environment Configuration
# =============================================================================

# --- Server ---
PORT=4623
HOST=127.0.0.1

# --- Database ---
# DATABASE_URL=sqlite:///path/to/openproxy.db

# --- Auth ---
# JWT_SECRET=your-secret-here
# ENCRYPTION_KEY=your-32-byte-encryption-key
# REQUIRE_API_KEY=true

# --- Observability ---
# OBSERVABILITY_ENABLED=true
# OBSERVABILITY_MAX_JSON_SIZE=5120

# --- Timeouts ---
# STREAM_STALL_TIMEOUT_MS=360000
# STREAM_FIRST_CHUNK_TIMEOUT_MS=200000

# --- OAuth Endpoint Overrides ---
# OPENPROXY_OPENAI_TOKEN_URL=
# OPENPROXY_GEMINI_TOKEN_URL=
# OPENPROXY_CODEX_TOKEN_URL=
# OPENPROXY_KIRO_TOKEN_URL=
