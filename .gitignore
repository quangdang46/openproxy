# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.bin/*
# Top-level `data/` is the Next.js side-app's scratch directory. Anchor with
# a leading slash so we don't sweep up Rust-side data dirs like
# `src/core/config/data/` that ship include_str! payloads.
/data/
logs/*
source/*
.cursor/*
docs/*
!docs/ARCHITECTURE.md
!docs/integrations/
test/*
bin/*
open-sse/test/*
RM.vn.md
RM.md
cursor/*
PUBLIC.md
Thanks.md
PUBLIC.en.md
PR/*

#Ignore vscode AI rules
.github/instructions/codacy.instructions.md
README1.md
deploy*.sh
ecosystem.config.*

scripts/agSniffer/*
gitbooks/*


# Added by cargo

/target

# bv (beads viewer) local config and caches
.bv/

# npm distribution: binaries are staged into platform packages at release time,
# never committed. The bin/.gitkeep stubs themselves are tracked.
/packages/platform/*/bin/openproxy
/packages/platform/*/bin/openproxy.exe
.ms/
HANDOFF.md
.ntm/
